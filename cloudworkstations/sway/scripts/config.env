# =============================================================================
# ☕ Cloud Workstation Configuration
# =============================================================================

# Infrastructure
REGION="us-central1"
CLUSTER="workstation-cluster"
CONFIG="ws-config"
WORKSTATION="dev-workstation"
AR_REPO="workstation-images"

# Automation
TOPIC_NAME="sway-image-trigger-topic"
SCHEDULER_JOB_NAME="sway-image-weekly-job"
TRIGGER_ON_CHANGE_NAME="sway-image-update-on-change"
TRIGGER_WEEKLY_NAME="sway-image-weekly-update"

# Machine Specs
MACHINE_TYPE="n1-standard-16"
ACCELERATOR_TYPE="nvidia-tesla-t4"
ACCELERATOR_COUNT=1
DISK_SIZE=500
DISK_TYPE="pd-ssd"
